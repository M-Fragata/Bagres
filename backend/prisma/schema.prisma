generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedules {
  id        String   @id @default(uuid())
  atleta    String
  date      String
  hour      String

  atleta_id String?  // Começa como opcional para a migration aceitar dados antigos
  atletaRel Atletas? @relation(fields: [atleta_id], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Schedules")
}

model Atletas {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  role      String @default("user")

  schedules Schedules[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Atletas")
}

model Config {
  id        Int      @id @default(1)
  dias      Json
  horarios  Json
  updatedAt DateTime @updatedAt
}